{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignoreFiles": ["libs/**/benchmark/*.bench.ts", ".config/**"],
  "ignoreDependencies": [
    "@biomejs/.+",
    "@commitlint/.+",
    "bunup",
    "@effect/tsgo",
    "varlock",
    // unused as dev dependency in some projects, fix later
    "@effect/platform-bun"
  ],
  "ignoreBinaries": ["mise"],
  "ignoreWorkspaces": ["scripts", "examples", "scratchpad"],
  "workspaces": {
    ".": {}
  }
}
