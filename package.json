{
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "lint": "bunx --bun @biomejs/biome format --write",
    "check": "tsgo --noEmit",
    "test": "vitest run",
    "prepare": "husky"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "libs/*",
      "plugins/*",
      "scripts",
      "examples",
      "scratchpad"
    ],
    "catalog": {
      "effect": "^4.0.0-beta.36",
      "@effect/platform-bun": "^4.0.0-beta.36",
      "@types/bun": "1.3.11",
      "@types/node": "^22.5.4"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@effect/language-service": "^0.81.0",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "^7.0.0-dev.20260407.1",
    "bunup": "^0.16.31",
    "husky": "^9.1.7",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.0"
  }
}
